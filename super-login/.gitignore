# Node modules directory (generated by npm install)
node_modules/

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Dependency directories
jspm_packages/
dist/

# Output of build tools like grunt
/build/

# macOS system files
.DS_Store
.AppleDouble
.LSOverride

# Icon must end with two \r
Icon
._*

# Thumbnails
.TemporaryItems
.Trashes

# Files that might appear on external disk drives
.Spotlight-V100
.VolumeIcon.icns

# Directories potentially created on remote Mac
.fseventsd
.com.apple.timemachine.donotpresent

# Compiled Python files
__pycache__/

# Compiled Electron files
*.asar
*.electron

# VS Code directories
.vscode/
.idea/

# Environment variable files (if used)
.env
.env.local
.env.production
.env.test

# Build artifact files
build/
